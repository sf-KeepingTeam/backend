# ==========================================
# Docker Compose 환경변수 템플릿
# ==========================================
# 사용법:
# 1. 이 파일을 .env로 복사: cp .env.example .env
# 2. 실제 값으로 변경
# 3. .env 파일은 절대 git에 커밋하지 마세요!
# ==========================================

# Docker Hub 계정
DOCKER_USERNAME=your_dockerhub_username

# ==========================================
# 데이터베이스
# ==========================================
MYSQL_ROOT_PASSWORD=change_this_password
MYSQL_DATABASE=keeping

# ==========================================
# 인증/보안
# ==========================================
# JWT 시크릿 (256bit 이상, 직접 생성 권장)
# 생성 명령: openssl rand -base64 64
JWT_SECRET=your_jwt_secret_here_minimum_256_bits

# 내부 서비스 인증 토큰 (qr-service ↔ monolith 간 X-Internal-Auth 헤더)
# 미설정 시 하드코딩 기본값 internal-service-token-12345 로 동작하므로
# 운영 환경에서는 반드시 강한 값으로 교체
INTERNAL_AUTH_TOKEN=internal-service-token-12345

# ==========================================
# 결제 (Toss)
# ==========================================
# 테스트 키 (실제 결제 안 됨)
TOSS_SECRET_KEY=test_sk_xxxxxxxxxxxxxxxxxxxxxxxx

# ==========================================
# AWS S3 (선택)
# ==========================================
AWS_ACCESS_KEY=
AWS_SECRET_KEY=
AWS_REGION=ap-northeast-2
AWS_S3_BUCKET=

# ==========================================
# Clova OCR (선택)
# ==========================================
CLOVA_OCR_URL=
CLOVA_OCR_SECRET=
CLOVA_TEMPLATE_IDS=39076

# ==========================================
# OpenAI (선택)
# ==========================================
OPENAI_API_KEY=
OPENAI_API_URL=https://api.openai.com/v1/chat/completions

# ==========================================
# 개발/테스트 (⚠️ 운영 시 반드시 false)
# ==========================================
# true로 설정 시 POST /auth/dev-login 으로 Kakao 없이 JWT 발급 가능
# 운영 환경에서 true면 임의 사용자 사칭이 가능한 심각한 보안 취약점
LOADTEST_BACKDOOR_ENABLED=false
# 로컬 테스트 시: LOADTEST_BACKDOOR_ENABLED=true, SPRING_PROFILES_ACTIVE=prod,loadtest

# ==========================================
# 캐시 (qr-service)
# ==========================================
# NONE / CACHE_ASIDE / WRITE_THROUGH
CACHE_MODE=WRITE_THROUGH
CACHE_WARMING_ENABLED=true

# ==========================================
# 모니터링
# ==========================================
GRAFANA_ADMIN_PASSWORD=change_this_password

# ==========================================
# 기타
# ==========================================
FE_BASE_URL=http://localhost:3030
