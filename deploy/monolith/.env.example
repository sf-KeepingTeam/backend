# Monolith 서버 환경변수

# Docker Hub 계정 (이미지 pull에 필요)
DOCKER_USERNAME=your_dockerhub_username

# MySQL 설정
MYSQL_ROOT_PASSWORD=secure_password_here

# JWT 시크릿 (QR Service와 동일해야 함)
JWT_SECRET=your_jwt_secret_here

# 내부 서비스 통신 토큰 (QR Service와 동일해야 함)
INTERNAL_AUTH_TOKEN=your_internal_token_here

# 프론트엔드 URL (CORS, 리다이렉트용)
FE_BASE_URL=http://localhost:3030
